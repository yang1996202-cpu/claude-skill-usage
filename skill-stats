#!/usr/bin/env python3
"""
skill-stats — 统计 Claude Code skill 使用情况

Usage:
    skill-stats                        # 自动探测目录并统计
    skill-stats --data-dir ~/.claude   # 手动指定数据目录
    skill-stats --top 10               # 只显示前 10
    skill-stats --by-session           # 按会话去重统计
    skill-stats --detail web-access    # 单个 skill 详情
    skill-stats --record-hook          # 读取 Claude Hook stdin 并写入日志
"""

import argparse
import json
import os
import sys
from collections import Counter, defaultdict
from datetime import datetime, timezone
from pathlib import Path


def find_claude_dir(cli_override=None):
    """自动探测 Claude Code 数据目录。优先级：
    1. 命令行 --data-dir
    2. 环境变量 CLAUDE_DATA_DIR
    3. 常见路径扫描（找得到 projects/ 子目录的）
    """
    if cli_override:
        p = Path(cli_override).expanduser().resolve()
        if (p / "projects").exists():
            return p
        print(f"警告: 指定目录 {p} 下没有 projects/ 子目录", file=sys.stderr)
        return p  # 仍返回，让后续代码报更具体的错

    # 环境变量
    env_dir = os.environ.get("CLAUDE_DATA_DIR")
    if env_dir:
        p = Path(env_dir).expanduser().resolve()
        if (p / "projects").exists():
            return p

    # 常见路径扫描
    candidates = [
        Path.home() / ".claude",
        Path.home() / ".config" / "claude",
        Path.home() / "Library" / "Application Support" / "Claude Code",
        Path.home() / ".local" / "share" / "claude",
    ]

    for cand in candidates:
        if (cand / "projects").exists():
            return cand

    # 都没找到，返回默认路径（让后续报错提示更清楚）
    return Path.home() / ".claude"


def parse_projects(projects_dir, hook_log):
    """Parse all JSONL files in projects_dir and hook_log."""
    skill_sessions = defaultdict(set)
    skill_messages = Counter()
    skill_timestamps = defaultdict(list)
    skill_hook_calls = Counter()

    if projects_dir.exists():
        for jsonl_file in projects_dir.rglob("*.jsonl"):
            try:
                with open(jsonl_file, "r", encoding="utf-8") as f:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            obj = json.loads(line)
                        except json.JSONDecodeError:
                            continue

                        session_id = obj.get("sessionId", "unknown")
                        timestamp = obj.get("timestamp", "")

                        # attributionSkill: marks which skill triggered this message
                        attr = obj.get("attributionSkill")
                        if attr:
                            skill_sessions[attr].add(session_id)
                            skill_messages[attr] += 1
                            if timestamp:
                                skill_timestamps[attr].append(timestamp)

                        # Also check explicit Skill tool_use
                        if obj.get("type") == "assistant" and "message" in obj:
                            content = obj.get("message", {}).get("content", [])
                            for item in content:
                                if isinstance(item, dict) and item.get("type") == "tool_use":
                                    if item.get("name") == "Skill":
                                        skill_name = item.get("input", {}).get("skill", "unknown")
                                        skill_sessions[skill_name].add(session_id)
                                        skill_messages[skill_name] += 1
                                        if timestamp:
                                            skill_timestamps[skill_name].append(timestamp)
            except Exception:
                pass

    # Parse hook log for real-time skill usage
    if hook_log.exists():
        try:
            with open(hook_log, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        obj = json.loads(line)
                        skill_name = obj.get("skill", "unknown")
                        timestamp = obj.get("timestamp", "")
                        skill_hook_calls[skill_name] += 1
                        if timestamp:
                            skill_timestamps[skill_name].append(timestamp)
                    except json.JSONDecodeError:
                        continue
        except Exception:
            pass

    return skill_sessions, skill_messages, skill_timestamps, skill_hook_calls


def format_table(rows, headers):
    """Simple table formatter."""
    if not rows:
        return "(no data)"

    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(str(cell)))

    lines = []
    sep = " │ ".join("─" * w for w in widths)
    header = " │ ".join(str(h).ljust(w) for h, w in zip(headers, widths))
    lines.append(header)
    lines.append(sep)
    for row in rows:
        lines.append(" │ ".join(str(c).ljust(w) for c, w in zip(row, widths)))
    return "\n".join(lines)


def record_hook_event(data_dir):
    """Read a Claude Code hook payload from stdin and append a usage record."""
    try:
        payload = json.load(sys.stdin)
    except json.JSONDecodeError as exc:
        print(f"无效 Hook JSON: {exc}", file=sys.stderr)
        return 1

    tool_name = payload.get("tool_name")
    if tool_name and tool_name != "Skill":
        return 0

    tool_input = payload.get("tool_input") or {}
    if not isinstance(tool_input, dict):
        return 0

    skill_name = tool_input.get("skill")
    if not skill_name:
        return 0

    logs_dir = data_dir / "logs"
    logs_dir.mkdir(parents=True, exist_ok=True)
    log_path = logs_dir / "skill-usage.jsonl"
    record = {
        "timestamp": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "skill": skill_name,
    }

    with open(log_path, "a", encoding="utf-8") as f:
        f.write(json.dumps(record, ensure_ascii=False) + "\n")

    return 0


def main():
    parser = argparse.ArgumentParser(description="统计 Claude Code skill 使用情况")
    parser.add_argument("--data-dir", help="手动指定 Claude Code 数据目录（默认自动探测）")
    parser.add_argument("--top", type=int, default=20, help="显示前 N 个")
    parser.add_argument("--by-session", action="store_true", help="按会话去重统计")
    parser.add_argument("--detail", help="查看某个 skill 的详细记录")
    parser.add_argument("--record-hook", action="store_true", help="读取 Claude Hook stdin 并写入 skill-usage.jsonl")
    args = parser.parse_args()

    data_dir = find_claude_dir(args.data_dir)
    if args.record_hook:
        return record_hook_event(data_dir)

    projects_dir = data_dir / "projects"
    hook_log = data_dir / "logs" / "skill-usage.jsonl"

    skill_sessions, skill_messages, skill_timestamps, skill_hook_calls = parse_projects(
        projects_dir, hook_log
    )

    if not skill_sessions and not skill_hook_calls:
        searched = [str(data_dir)]
        if not args.data_dir:
            searched = [
                str(Path.home() / ".claude"),
                str(Path.home() / ".config" / "claude"),
                str(Path.home() / "Library" / "Application Support" / "Claude Code"),
            ]
        print("没有数据。", file=sys.stderr)
        print(f"搜索过的目录: {', '.join(searched)}", file=sys.stderr)
        print("", file=sys.stderr)
        print("可能原因：", file=sys.stderr)
        print("  1. Claude Code 还没有生成 projects 数据（多聊几句就有了）", file=sys.stderr)
        print("  2. 数据目录不在默认位置，用 --data-dir 指定", file=sys.stderr)
        print("  3. Hook 未配置或尚未生效（需重启 Claude Code）", file=sys.stderr)
        print("", file=sys.stderr)
        print("设置数据目录环境变量：export CLAUDE_DATA_DIR=/path/to/.claude", file=sys.stderr)
        return 1

    if args.detail:
        skill = args.detail
        sessions = skill_sessions.get(skill, set())
        messages = skill_messages.get(skill, 0)
        hook_calls = skill_hook_calls.get(skill, 0)
        timestamps = skill_timestamps.get(skill, [])
        print(f"Skill: {skill}")
        print(f"  触发会话数: {len(sessions)}")
        print(f"  产生消息数: {messages}")
        print(f"  Hook 记录调用: {hook_calls}")
        if timestamps:
            try:
                dates = sorted(set(t[:10] for t in timestamps if len(t) >= 10))
                print(f"  使用日期: {', '.join(dates[:10])}")
                if len(dates) > 10:
                    print(f"  ... 共 {len(dates)} 天")
            except Exception:
                pass
        return 0

    # Merge all skill names from both sources
    all_skills = set(skill_sessions.keys()) | set(skill_hook_calls.keys())

    if args.by_session:
        items = sorted(
            (
                (len(skill_sessions.get(name, set())), skill_messages.get(name, 0), skill_hook_calls.get(name, 0), name)
                for name in all_skills
            ),
            key=lambda x: -(x[0] + x[2]),
        )
        rows = [
            (i + 1, name, sessions, msgs, hooks)
            for i, (sessions, msgs, hooks, name) in enumerate(items[: args.top])
        ]
        print(format_table(rows, ["#", "Skill", "会话数", "消息数", "Hook记录"]))
    else:
        items = sorted(
            (
                (skill_messages.get(name, 0), len(skill_sessions.get(name, set())), skill_hook_calls.get(name, 0), name)
                for name in all_skills
            ),
            key=lambda x: -(x[0] + x[2]),
        )
        rows = [
            (i + 1, name, msgs, sessions, hooks)
            for i, (msgs, sessions, hooks, name) in enumerate(items[: args.top])
        ]
        print(format_table(rows, ["#", "Skill", "消息数", "会话数", "Hook记录"]))

    total_sessions = len(set().union(*skill_sessions.values())) if skill_sessions else 0
    total_messages = sum(skill_messages.values())
    total_hooks = sum(skill_hook_calls.values())
    print(f"\n总计: {len(all_skills)} 个 skill, {total_sessions} 个会话, {total_messages} 条消息, {total_hooks} 次 hook 记录")
    print(f"数据目录: {data_dir}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
