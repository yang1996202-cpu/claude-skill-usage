#!/usr/bin/env python3
"""
skill-stats — 统计 Claude Code skill 使用情况

Usage:
    skill-stats              # 统计所有 projects 目录下的 skill 使用
    skill-stats --top 10     # 只显示前 10
    skill-stats --by-session # 按会话去重统计
    skill-stats --detail skill-name  # 查看某个 skill 的详细使用记录
"""

import argparse
import json
import sys
from collections import Counter, defaultdict
from datetime import datetime
from pathlib import Path

PROJECTS_DIR = Path.home() / ".claude" / "projects"
HOOK_LOG = Path.home() / ".claude" / "logs" / "skill-usage.jsonl"


def parse_projects():
    """Parse all JSONL files in ~/.claude/projects/"""
    skill_sessions = defaultdict(set)  # skill -> set of session IDs
    skill_messages = Counter()         # skill -> message count
    skill_timestamps = defaultdict(list)
    skill_hook_calls = Counter()       # skill -> hook-recorded calls

    if not PROJECTS_DIR.exists():
        return skill_sessions, skill_messages, skill_timestamps, skill_hook_calls

    for jsonl_file in PROJECTS_DIR.rglob("*.jsonl"):
        try:
            with open(jsonl_file, 'r', encoding='utf-8') as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        obj = json.loads(line)
                    except json.JSONDecodeError:
                        continue

                    session_id = obj.get('sessionId', 'unknown')
                    timestamp = obj.get('timestamp', '')

                    # attributionSkill: marks which skill triggered this message
                    attr = obj.get('attributionSkill')
                    if attr:
                        skill_sessions[attr].add(session_id)
                        skill_messages[attr] += 1
                        if timestamp:
                            skill_timestamps[attr].append(timestamp)

                    # Also check explicit Skill tool_use
                    if obj.get('type') == 'assistant' and 'message' in obj:
                        content = obj.get('message', {}).get('content', [])
                        for item in content:
                            if isinstance(item, dict) and item.get('type') == 'tool_use':
                                if item.get('name') == 'Skill':
                                    skill_name = item.get('input', {}).get('skill', 'unknown')
                                    skill_sessions[skill_name].add(session_id)
                                    skill_messages[skill_name] += 1
                                    if timestamp:
                                        skill_timestamps[skill_name].append(timestamp)
        except Exception:
            pass

    # Parse hook log for real-time skill usage
    if HOOK_LOG.exists():
        try:
            with open(HOOK_LOG, 'r', encoding='utf-8') as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        obj = json.loads(line)
                        skill_name = obj.get('skill', 'unknown')
                        timestamp = obj.get('timestamp', '')
                        skill_hook_calls[skill_name] += 1
                        if timestamp:
                            skill_timestamps[skill_name].append(timestamp)
                    except json.JSONDecodeError:
                        continue
        except Exception:
            pass

    return skill_sessions, skill_messages, skill_timestamps, skill_hook_calls


def format_table(rows, headers):
    """Simple table formatter."""
    if not rows:
        return "(no data)"

    cols = len(headers)
    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(str(cell)))

    lines = []
    sep = " │ ".join("─" * w for w in widths)
    header = " │ ".join(str(h).ljust(w) for h, w in zip(headers, widths))
    lines.append(header)
    lines.append(sep)
    for row in rows:
        lines.append(" │ ".join(str(c).ljust(w) for c, w in zip(row, widths)))
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(description="统计 Claude Code skill 使用情况")
    parser.add_argument("--top", type=int, default=20, help="显示前 N 个")
    parser.add_argument("--by-session", action="store_true", help="按会话去重统计")
    parser.add_argument("--detail", help="查看某个 skill 的详细记录")
    args = parser.parse_args()

    skill_sessions, skill_messages, skill_timestamps, skill_hook_calls = parse_projects()

    if not skill_sessions and not skill_hook_calls:
        print("没有数据。检查 ~/.claude/projects/ 是否存在，或 hook 是否已生效。")
        return 1

    if args.detail:
        skill = args.detail
        sessions = skill_sessions.get(skill, set())
        messages = skill_messages.get(skill, 0)
        hook_calls = skill_hook_calls.get(skill, 0)
        timestamps = skill_timestamps.get(skill, [])
        print(f"Skill: {skill}")
        print(f"  触发会话数: {len(sessions)}")
        print(f"  产生消息数: {messages}")
        print(f"  Hook 记录调用: {hook_calls}")
        if timestamps:
            try:
                dates = sorted(set(t[:10] for t in timestamps if len(t) >= 10))
                print(f"  使用日期: {', '.join(dates[:10])}")
                if len(dates) > 10:
                    print(f"  ... 共 {len(dates)} 天")
            except Exception:
                pass
        return 0

    # Merge all skill names from both sources
    all_skills = set(skill_sessions.keys()) | set(skill_hook_calls.keys())

    if args.by_session:
        # Sort by unique session count + hook calls
        items = sorted(
            ((len(skill_sessions.get(name, set())), skill_messages.get(name, 0), skill_hook_calls.get(name, 0), name) for name in all_skills),
            key=lambda x: -(x[0] + x[2])
        )
        rows = [
            (i + 1, name, sessions, msgs, hooks)
            for i, (sessions, msgs, hooks, name) in enumerate(items[:args.top])
        ]
        print(format_table(rows, ["#", "Skill", "会话数", "消息数", "Hook记录"]))
    else:
        # Sort by message count + hook calls
        items = sorted(
            ((skill_messages.get(name, 0), len(skill_sessions.get(name, set())), skill_hook_calls.get(name, 0), name) for name in all_skills),
            key=lambda x: -(x[0] + x[2])
        )
        rows = [
            (i + 1, name, msgs, sessions, hooks)
            for i, (msgs, sessions, hooks, name) in enumerate(items[:args.top])
        ]
        print(format_table(rows, ["#", "Skill", "消息数", "会话数", "Hook记录"]))

    total_sessions = len(set().union(*skill_sessions.values())) if skill_sessions else 0
    total_messages = sum(skill_messages.values())
    total_hooks = sum(skill_hook_calls.values())
    print(f"\n总计: {len(all_skills)} 个 skill, {total_sessions} 个会话, {total_messages} 条消息, {total_hooks} 次 hook 记录")
    print(f"数据源: projects JSONL + hook 日志 ({HOOK_LOG})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
